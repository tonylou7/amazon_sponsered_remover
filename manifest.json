{
  "manifest_version": 3,
  "name": "Amazon Sponsored Filter",
  "version": "1.0",
  "description": "Removes sponsored product listings from Amazon search results.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.com/*",
        "https://www.amazon.ca/*",
        "https://www.amazon.co.uk/*",
        "https://www.amazon.de/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
